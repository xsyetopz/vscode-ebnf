{
  "W3C production": {
    "prefix": "rule",
    "body": [
      "[${1:1}] ${2:name} ::= ${3:expression}"
    ],
    "description": "W3C XML EBNF production"
  },
  "Character code": {
    "prefix": "hex",
    "body": [
      "#x${1:20}"
    ],
    "description": "W3C XML EBNF character code"
  },
  "Character range": {
    "prefix": "range",
    "body": [
      "[#x${1:20}-#x${2:7E}]"
    ],
    "description": "W3C XML EBNF character range"
  },
  "Alternatives": {
    "prefix": "alt",
    "body": [
      "${1:name} ::= ${2:first}",
      "    | ${3:second}"
    ],
    "description": "W3C XML EBNF alternatives"
  }
}
