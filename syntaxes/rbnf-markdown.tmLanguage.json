{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "RBNF Markdown Code Block",
  "scopeName": "text.html.markdown.rbnf.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    {
      "begin": "(^|\\G)(\\s*)(```|~~~)\\s*(?i:(rbnf))\\s*$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.markdown" },
        "4": { "name": "fenced_code.block.language.markdown" }
      },
      "end": "(^|\\G)(\\2|\\s{0,3})(\\3)\\s*$",
      "endCaptures": { "3": { "name": "punctuation.definition.markdown" } },
      "contentName": "meta.embedded.block.rbnf",
      "patterns": [ { "include": "source.rbnf" } ]
    }
  ]
}
