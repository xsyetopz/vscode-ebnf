{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "RBNF",
  "scopeName": "source.rbnf",
  "patterns": [
    { "include": "#comment" },
    { "include": "#rule-definition" },
    { "include": "#expression" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.semicolon.rbnf",
      "begin": "(;)",
      "beginCaptures": { "1": { "name": "punctuation.definition.comment.rbnf" } },
      "end": "(?=\\n)"
    },
    "rule-definition": {
      "match": "^\\s*(<[^<>\\r\\n]+>|[A-Za-z_][A-Za-z0-9_.:-]*)(\\s*)(::=)",
      "captures": {
        "1": { "name": "entity.name.function.rule.rbnf" },
        "3": { "name": "keyword.operator.assignment.rbnf" }
      }
    },
    "expression": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#repetition-prefix" },
        { "include": "#repetition-range" },
        { "include": "#double-string" },
        { "include": "#single-string" },
        { "include": "#alternation" },
        { "include": "#suffix-repetition" },
        { "include": "#group-delimiter" },
        { "include": "#identifier" }
      ]
    },
    "repetition-prefix": {
      "name": "constant.numeric.repetition.rbnf",
      "match": "\\b\\d+(?=\\*)"
    },
    "repetition-range": {
      "name": "keyword.operator.repetition.rbnf",
      "match": "\\d*\\*\\d*"
    },
    "double-string": {
      "name": "string.quoted.double.rbnf",
      "begin": "(\\\")",
      "beginCaptures": { "1": { "name": "punctuation.definition.string.begin.rbnf" } },
      "end": "(\\\")|(?=\\n)",
      "endCaptures": { "1": { "name": "punctuation.definition.string.end.rbnf" } }
    },
    "single-string": {
      "name": "string.quoted.single.rbnf",
      "begin": "(')",
      "beginCaptures": { "1": { "name": "punctuation.definition.string.begin.rbnf" } },
      "end": "(')|(?=\\n)",
      "endCaptures": { "1": { "name": "punctuation.definition.string.end.rbnf" } }
    },
    "alternation": {
      "name": "keyword.operator.alternation.rbnf",
      "match": "\\|"
    },
    "suffix-repetition": {
      "name": "keyword.operator.repetition.rbnf",
      "match": "[?+*]"
    },
    "group-delimiter": {
      "name": "punctuation.definition.group.rbnf",
      "match": "[()\\[\\]{}]"
    },
    "identifier": {
      "name": "variable.other.rule.rbnf",
      "match": "<[^<>\\r\\n]+>|[A-Za-z_][A-Za-z0-9_.:-]*"
    }
  }
}
