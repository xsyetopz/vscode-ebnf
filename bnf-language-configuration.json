{
  "comments": {
    "lineComment": {
      "comment": ";"
    },
    "blockComment": [
      "/*",
      "*/"
    ]
  },
  "brackets": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "{",
      "}"
    ],
    [
      "<",
      ">"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "'",
      "close": "'"
    },
    {
      "open": "<",
      "close": ">"
    }
  ],
  "surroundingPairs": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "{",
      "}"
    ],
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ],
    [
      "<",
      ">"
    ]
  ],
  "wordPattern": "(<[^<>\\r\\n]+>|[A-Za-z_][A-Za-z0-9_.:-]*|[A-Za-z][A-Za-z0-9-]*)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(?:<[^<>\\r\\n]+>|[A-Za-z_][A-Za-z0-9_.:-]*|[A-Za-z][A-Za-z0-9-]*)\\s*(?:::=|=\\/|=)",
    "decreaseIndentPattern": "^\\S"
  }
}
